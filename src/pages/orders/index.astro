---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="My Orders">
  <div class="orders-container">
    <h1>My Orders</h1>
    <div class="orders-placeholder">
      <p>No orders found. Your order history will appear here once you start shopping.</p>
      <a href="/" class="button primary">Start Shopping</a>
    </div>
  </div>
</Layout>

<style>
  .orders-container {
    max-width: 800px;
    margin: 40px auto;
    padding: 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  h1 {
    font-size: 32px;
    font-weight: 600;
    color: #333;
    margin-bottom: 32px;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 16px;
  }

  .orders-placeholder {
    text-align: center;
    padding: 60px 20px;
    background-color: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #e9ecef;
  }

  .orders-placeholder p {
    font-size: 16px;
    color: #666;
    margin-bottom: 24px;
  }

  .button {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .button.primary {
    background-color: #007bff;
    color: white;
  }

  .button.primary:hover {
    background-color: #0056b3;
  }

  @media (max-width: 568px) {
    .orders-container {
      margin: 20px auto;
      padding: 16px;
    }

    h1 {
      font-size: 24px;
    }

    .orders-placeholder {
      padding: 40px 16px;
    }
  }
</style>
